# Database 
DATABASE_URL="postgresql://user:password@host:5432/laundryapp"

# NextAuth
NEXTAUTH_SECRET="secret"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Credit package (4 credits per unit)
# This maps to the Stripe Price ID you create for the 4-credit unit
STRIPE_PRICE_4_CREDITS="price_..."

RESEND_API_KEY="re_..."

# Promo: free credits grant expiry (ISO date). Change or remove when promo ends.
FREE_CREDITS_PROMO_END="2026-04-20T00:00:00.000Z"

EMAIL_FROM="LaundryBox <test@domain.com>"

